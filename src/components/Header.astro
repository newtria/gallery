---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
---
<header class="header">
  <a href="/" class="header-brand">gallery</a>
  <div class="header-right">
    <nav class="header-nav">
      <a href="/" class:list={[{ active: currentPath === '/' }]}>갤러리</a>
      <a href="/commission" class:list={[{ active: currentPath === '/commission' }]}>커미션</a>
      <a class="header-link" href="https://heznpc.github.io" target="_blank" rel="noopener">heznpc.github.io</a>
    </nav>
    <button class="theme-btn" id="themeToggle" aria-label="Toggle theme"></button>
  </div>
</header>
