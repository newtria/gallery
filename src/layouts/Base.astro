---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'heznpc — gallery', description = '2차 창작 / 유머 일러스트 갤러리' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ko" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
  <slot />

  <script is:inline>
    (function() {
      var root = document.documentElement;
      try {
        var s = localStorage.getItem('gallery-theme');
        if (s) root.dataset.theme = s;
      } catch(e) {}

      var btn = document.getElementById('themeToggle');
      if (!btn) return;
      function u() { btn.textContent = root.dataset.theme === 'dark' ? '\u2600' : '\u263E'; }
      u();
      btn.addEventListener('click', function() {
        root.dataset.theme = root.dataset.theme === 'dark' ? 'light' : 'dark';
        try { localStorage.setItem('gallery-theme', root.dataset.theme); } catch(e) {}
        u();
      });
    })();
  </script>
</body>
</html>
